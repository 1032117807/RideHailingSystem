package service

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"net/http"
	"strings"
	"time"

	"ridehailing/backend/internal/model"
)

const (
	maxDriverAIPromptLength     = 1200
	maxPassengerAIMessages      = 8
	maxPassengerAIMessageLength = 500
)

type DriverTripAIDraft struct {
	Prompt             string   `json:"prompt"`
	TripName           string   `json:"tripName"`
	StartCity          string   `json:"startCity"`
	EndCity            string   `json:"endCity"`
	DepartureTimeLocal string   `json:"departureTimeLocal"`
	ArrivalTimeLocal   string   `json:"arrivalTimeLocal"`
	SeatTotal          int      `json:"seatTotal"`
	PriceCent          int      `json:"priceCent"`
	VehicleType        string   `json:"vehicleType"`
	Stops              []string `json:"stops"`
	Remark             string   `json:"remark"`
	Suggestions        []string `json:"suggestions"`
	Origin             string   `json:"origin"`
	Destination        string   `json:"destination"`
	DepartureTime      string   `json:"departureTime"`
	ArrivalTime        string   `json:"arrivalTime"`
	SeatCount          int      `json:"seatCount"`
	Seats              int      `json:"seats"`
	Response           string   `json:"response"`
}

type AIChatMessage struct {
	Role    string `json:"role"`
	Content string `json:"content"`
}

type PassengerAIChatResult struct {
	Reply       string   `json:"reply"`
	Response    string   `json:"response"`
	Suggestions []string `json:"suggestions"`
}

type AIService struct {
	apiKey   string
	baseURL  string
	model    string
	client   *http.Client
	endpoint string
}

func NewAIService(apiKey, baseURL, model string, timeout time.Duration) *AIService {
	baseURL = strings.TrimRight(strings.TrimSpace(baseURL), "/")
	if baseURL == "" {
		baseURL = "https://api.openai.com/v1"
	}
	if strings.TrimSpace(model) == "" {
		model = "gpt-5-mini"
	}
	if timeout <= 0 {
		timeout = 20 * time.Second
	}

	return &AIService{
		apiKey:   strings.TrimSpace(apiKey),
		baseURL:  baseURL,
		model:    strings.TrimSpace(model),
		client:   &http.Client{Timeout: timeout},
		endpoint: baseURL + "/responses",
	}
}

func (s *AIService) GenerateDriverTripDraft(ctx context.Context, currentUserRole, prompt string) (*DriverTripAIDraft, error) {
	if currentUserRole != model.RoleDriver {
		return nil, errors.New("only driver can use driver AI")
	}
	if s.apiKey == "" {
		return nil, errors.New("OPENAI_API_KEY is not configured")
	}

	prompt = strings.TrimSpace(prompt)
	if prompt == "" {
		return nil, errors.New("prompt is required")
	}
	if len([]rune(prompt)) > maxDriverAIPromptLength {
		return nil, fmt.Errorf("prompt is too long, max %d characters", maxDriverAIPromptLength)
	}

	requestBody := map[string]interface{}{
		"model":             s.model,
		"max_output_tokens": 600,
		"input": []map[string]interface{}{
			{
				"role": "system",
				"content": []map[string]string{
					{
						"type": "input_text",
						"text": strings.Join([]string{
							"You extract a structured driver trip draft for a Chinese intercity ride scheduling app.",
							"Return only data that matches the provided JSON schema.",
							"All time fields must use local format YYYY-MM-DDTHH:mm.",
							"PriceCent in this project actually means whole-number yuan, not real cents.",
							"VehicleType must be one of: 商务大巴, 城际快线, 拼车专线.",
							"Prefer exact field names: tripName, startCity, endCity, departureTimeLocal, arrivalTimeLocal, seatTotal, priceCent, vehicleType, stops, remark, suggestions.",
							"If the user omits duration, infer a reasonable arrival time after departure.",
							"If stops are missing, return an empty array.",
							"Keep suggestions concise and practical for a driver.",
						}, " "),
					},
				},
			},
			{
				"role": "user",
				"content": []map[string]string{
					{
						"type": "input_text",
						"text": prompt,
					},
				},
			},
		},
		"text": map[string]interface{}{
			"format": map[string]interface{}{
				"type":   "json_schema",
				"name":   "driver_trip_draft",
				"strict": true,
				"schema": map[string]interface{}{
					"type":                 "object",
					"additionalProperties": false,
					"required": []string{
						"tripName",
						"startCity",
						"endCity",
						"departureTimeLocal",
						"arrivalTimeLocal",
						"seatTotal",
						"priceCent",
						"vehicleType",
						"stops",
						"remark",
						"suggestions",
					},
					"properties": map[string]interface{}{
						"tripName":           map[string]interface{}{"type": "string", "minLength": 1},
						"startCity":          map[string]interface{}{"type": "string", "minLength": 1},
						"endCity":            map[string]interface{}{"type": "string", "minLength": 1},
						"departureTimeLocal": map[string]interface{}{"type": "string"},
						"arrivalTimeLocal":   map[string]interface{}{"type": "string"},
						"seatTotal":          map[string]interface{}{"type": "integer", "minimum": 1},
						"priceCent":          map[string]interface{}{"type": "integer", "minimum": 1},
						"vehicleType": map[string]interface{}{
							"type": "string",
							"enum": []string{"商务大巴", "城际快线", "拼车专线"},
						},
						"stops": map[string]interface{}{
							"type": "array",
							"items": map[string]interface{}{
								"type": "string",
							},
						},
						"remark": map[string]interface{}{"type": "string"},
						"suggestions": map[string]interface{}{
							"type": "array",
							"items": map[string]interface{}{
								"type": "string",
							},
						},
					},
				},
			},
		},
	}
	
	fmt.Println("driver trip draft request body:", requestBody)

	text, err := s.requestResponseText(ctx, requestBody)
	if err != nil {
		return nil, err
	}

	fmt.Println("model raw text:", text)

	var draft DriverTripAIDraft
	if err := json.Unmarshal([]byte(text), &draft); err != nil {
		return nil, fmt.Errorf("parse model output failed: %w", err)
	}

	draft.Prompt = prompt
	reconcileDriverTripDraft(&draft)
	normalizeDriverTripDraft(&draft)
	if err := validateDriverTripDraft(&draft); err != nil {
		return nil, err
	}

	return &draft, nil
}

func (s *AIService) ChatPassenger(ctx context.Context, messages []AIChatMessage) (*PassengerAIChatResult, error) {
	if s.apiKey == "" {
		return nil, errors.New("OPENAI_API_KEY is not configured")
	}

	normalized := normalizeChatMessages(messages)
	if len(normalized) == 0 {
		return nil, errors.New("messages are required")
	}

	input := make([]map[string]interface{}, 0, len(normalized)+1)
	input = append(input, map[string]interface{}{
		"role": "system",
		"content": []map[string]string{
			{
				"type": "input_text",
				"text": strings.Join([]string{
					"You are a helpful Chinese travel assistant for an intercity ticketing app.",
					"Do not invent real-time inventory, exact train numbers, or refund rules unless the user already provided them.",
					"If information is uncertain, say it is a suggestion rather than a confirmed fact.",
					"Reply in simplified Chinese.",
					"Return only data matching the JSON schema.",
				}, " "),
			},
		},
	})

	for _, msg := range normalized {
		input = append(input, map[string]interface{}{
			"role": msg.Role,
			"content": []map[string]string{
				{
					"type": "input_text",
					"text": msg.Content,
				},
			},
		})
	}

	requestBody := map[string]interface{}{
		"model":             s.model,
		"max_output_tokens": 500,
		"input":             input,
		"text": map[string]interface{}{
			"format": map[string]interface{}{
				"type":   "json_schema",
				"name":   "passenger_ai_chat",
				"strict": true,
				"schema": map[string]interface{}{
					"type":                 "object",
					"additionalProperties": false,
					"required":             []string{"reply", "suggestions"},
					"properties": map[string]interface{}{
						"reply": map[string]interface{}{"type": "string", "minLength": 1},
						"suggestions": map[string]interface{}{
							"type": "array",
							"items": map[string]interface{}{
								"type": "string",
							},
						},
					},
				},
			},
		},
	}

	text, err := s.requestResponseText(ctx, requestBody)
	if err != nil {
		return nil, err
	}

	fmt.Println("model raw text:", text)

	var result PassengerAIChatResult
	if err := json.Unmarshal([]byte(text), &result); err != nil {
		return nil, fmt.Errorf("parse model output failed: %w", err)
	}

	result.Reply = strings.TrimSpace(result.Reply)
	result.Response = strings.TrimSpace(result.Response)
	if result.Reply == "" && result.Response != "" {
		result.Reply = result.Response
	}
	cleanSuggestions := make([]string, 0, len(result.Suggestions))
	for _, item := range result.Suggestions {
		item = strings.TrimSpace(item)
		if item == "" {
			continue
		}
		cleanSuggestions = append(cleanSuggestions, item)
	}
	result.Suggestions = cleanSuggestions

	if result.Reply == "" {
		return nil, errors.New("model returned empty reply")
	}

	return &result, nil
}

func (s *AIService) requestResponseText(ctx context.Context, requestBody map[string]interface{}) (string, error) {
	payload, err := json.Marshal(requestBody)
	if err != nil {
		return "", err
	}

	req, err := http.NewRequestWithContext(ctx, http.MethodPost, s.endpoint, bytes.NewReader(payload))
	if err != nil {
		return "", err
	}
	req.Header.Set("Authorization", "Bearer "+s.apiKey)
	req.Header.Set("Content-Type", "application/json")

	resp, err := s.client.Do(req)
	if err != nil {
		return "", err
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
	if err != nil {
		return "", err
	}

	if resp.StatusCode >= http.StatusBadRequest {
		return "", parseOpenAIHTTPError(resp.StatusCode, body)
	}

	var envelope openAIResponsesCreateResponse
	if err := json.Unmarshal(body, &envelope); err != nil {
		return "", err
	}

	return envelope.outputText()
}

type openAIResponsesCreateResponse struct {
	Output []openAIResponseOutputItem `json:"output"`
}

type openAIResponseOutputItem struct {
	Type    string                      `json:"type"`
	Content []openAIResponseContentItem `json:"content"`
}

type openAIResponseContentItem struct {
	Type    string `json:"type"`
	Text    string `json:"text"`
	Refusal string `json:"refusal"`
}

func (r *openAIResponsesCreateResponse) outputText() (string, error) {
	for _, item := range r.Output {
		for _, content := range item.Content {
			if content.Type == "refusal" && strings.TrimSpace(content.Refusal) != "" {
				return "", errors.New(strings.TrimSpace(content.Refusal))
			}
			if content.Type == "output_text" && strings.TrimSpace(content.Text) != "" {
				return strings.TrimSpace(content.Text), nil
			}
		}
	}
	return "", errors.New("model returned empty output")
}

func parseOpenAIHTTPError(statusCode int, body []byte) error {
	var envelope struct {
		Error struct {
			Message string `json:"message"`
			Type    string `json:"type"`
			Code    string `json:"code"`
		} `json:"error"`
	}

	if err := json.Unmarshal(body, &envelope); err == nil && strings.TrimSpace(envelope.Error.Message) != "" {
		return fmt.Errorf("openai api error (%d): %s", statusCode, strings.TrimSpace(envelope.Error.Message))
	}

	message := strings.TrimSpace(string(body))
	if message == "" {
		message = http.StatusText(statusCode)
	}
	return fmt.Errorf("openai api error (%d): %s", statusCode, message)
}

func normalizeDriverTripDraft(draft *DriverTripAIDraft) {
	draft.TripName = strings.TrimSpace(draft.TripName)
	draft.StartCity = strings.TrimSpace(draft.StartCity)
	draft.EndCity = strings.TrimSpace(draft.EndCity)
	draft.DepartureTimeLocal = strings.TrimSpace(draft.DepartureTimeLocal)
	draft.ArrivalTimeLocal = strings.TrimSpace(draft.ArrivalTimeLocal)
	draft.VehicleType = normalizeVehicleType(draft.VehicleType)
	draft.Remark = strings.TrimSpace(draft.Remark)

	stops := make([]string, 0, len(draft.Stops))
	seen := make(map[string]struct{}, len(draft.Stops))
	for _, stop := range draft.Stops {
		stop = strings.TrimSpace(stop)
		if stop == "" {
			continue
		}
		if _, ok := seen[stop]; ok {
			continue
		}
		seen[stop] = struct{}{}
		stops = append(stops, stop)
	}
	draft.Stops = stops

	suggestions := make([]string, 0, len(draft.Suggestions))
	for _, item := range draft.Suggestions {
		item = strings.TrimSpace(item)
		if item == "" {
			continue
		}
		suggestions = append(suggestions, item)
	}
	draft.Suggestions = suggestions
}

func reconcileDriverTripDraft(draft *DriverTripAIDraft) {
	draft.Origin = strings.TrimSpace(draft.Origin)
	draft.Destination = strings.TrimSpace(draft.Destination)
	draft.DepartureTime = strings.TrimSpace(draft.DepartureTime)
	draft.ArrivalTime = strings.TrimSpace(draft.ArrivalTime)
	draft.Response = strings.TrimSpace(draft.Response)

	if draft.StartCity == "" && draft.Origin != "" {
		draft.StartCity = draft.Origin
	}
	if draft.EndCity == "" && draft.Destination != "" {
		draft.EndCity = draft.Destination
	}
	if draft.DepartureTimeLocal == "" && draft.DepartureTime != "" {
		draft.DepartureTimeLocal = draft.DepartureTime
	}
	if draft.ArrivalTimeLocal == "" && draft.ArrivalTime != "" {
		draft.ArrivalTimeLocal = draft.ArrivalTime
	}
	if draft.SeatTotal <= 0 && draft.SeatCount > 0 {
		draft.SeatTotal = draft.SeatCount
	}
	if draft.SeatTotal <= 0 && draft.Seats > 0 {
		draft.SeatTotal = draft.Seats
	}
	if draft.TripName == "" && draft.StartCity != "" && draft.EndCity != "" {
		draft.TripName = draft.StartCity + " - " + draft.EndCity + " 班次"
	}
	if draft.Remark == "" && draft.Response != "" {
		draft.Remark = draft.Response
	}
}

func validateDriverTripDraft(draft *DriverTripAIDraft) error {
	if draft.TripName == "" || draft.StartCity == "" || draft.EndCity == "" {
		return errors.New("model output is missing required route fields")
	}
	if draft.StartCity == draft.EndCity {
		return errors.New("model output has the same start and end city")
	}
	departureTime, err := time.ParseInLocation("2006-01-02T15:04", draft.DepartureTimeLocal, time.Local)
	if err != nil {
		return errors.New("model output departureTimeLocal is invalid")
	}
	arrivalTime, err := time.ParseInLocation("2006-01-02T15:04", draft.ArrivalTimeLocal, time.Local)
	if err != nil {
		return errors.New("model output arrivalTimeLocal is invalid")
	}
	if !arrivalTime.After(departureTime) {
		return errors.New("model output arrivalTimeLocal must be later than departureTimeLocal")
	}
	if draft.SeatTotal <= 0 {
		return errors.New("model output seatTotal must be greater than 0")
	}
	if draft.PriceCent <= 0 {
		return errors.New("model output priceCent must be greater than 0")
	}
	if draft.VehicleType == "" {
		return errors.New("model output vehicleType is required")
	}
	if draft.Remark == "" {
		draft.Remark = "请在发布前补充上车点和行李说明。"
	}
	return nil
}

func normalizeVehicleType(raw string) string {
	raw = strings.TrimSpace(raw)
	switch raw {
	case "商务大巴", "城际快线", "拼车专线":
		return raw
	}
	switch {
	case strings.Contains(raw, "拼车"):
		return "拼车专线"
	case strings.Contains(raw, "快线"):
		return "城际快线"
	default:
		return "商务大巴"
	}
}

func normalizeChatMessages(messages []AIChatMessage) []AIChatMessage {
	result := make([]AIChatMessage, 0, len(messages))

	for _, msg := range messages {
		role := strings.ToLower(strings.TrimSpace(msg.Role))
		content := strings.TrimSpace(msg.Content)
		if role != "user" && role != "assistant" {
			continue
		}
		if content == "" {
			continue
		}

		runes := []rune(content)
		if len(runes) > maxPassengerAIMessageLength {
			content = string(runes[:maxPassengerAIMessageLength])
		}

		result = append(result, AIChatMessage{
			Role:    role,
			Content: content,
		})
	}

	if len(result) > maxPassengerAIMessages {
		result = result[len(result)-maxPassengerAIMessages:]
	}

	return result
}
